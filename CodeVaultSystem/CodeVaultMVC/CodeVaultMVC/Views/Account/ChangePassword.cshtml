@model CodeVaultMVC.ViewModels.ChangePasswordViewModel
@{
    Layout = "_AuthLayout"; 
    var role = ViewBag.SelectedRole as string;
    var isDeveloper = role == "Developer";
    ViewData["Title"] = isDeveloper ? "Geliştirici Şifre Değiştirme" : "Yönetici Şifre Değiştirme";
}

@if (isDeveloper)
{
    <style>
        .form-control:focus {
            border-color: #da70d6 !important;
            box-shadow: 0 0 0 3px rgba(218, 112, 214, 0.2) !important;
        }
        .btn-primary {
            background: linear-gradient(135deg, #8a2be2, #da70d6) !important;
        }
        .btn-primary:hover {
            filter: brightness(1.15);
        }
        .auth-logo span, .back-link-highlight {
            color: #da70d6 !important;
        }
    </style>
}
else
{
    <style>
        .form-control:focus {
            border-color: #00bfff !important;
            box-shadow: 0 0 0 3px rgba(0, 191, 255, 0.2) !important;
        }
        .btn-primary {
            background: linear-gradient(135deg, #00bfff, #00f2fe) !important;
        }
        .btn-primary:hover {
            filter: brightness(1.15);
        }
        .auth-logo span, .back-link-highlight {
            color: #00bfff !important;
        }
    </style>
}

<h5 class="text-white fw-semibold mb-1">Yeni şifre belirle</h5>
<p style="color:rgba(255,255,255,0.4); font-size:0.85rem;" class="mb-4">Güvenli bir şifre oluştur</p>

<form asp-action="ChangePassword" asp-route-role="@role" method="post">
    <input type="hidden" name="role" value="@role" />
    <input type="hidden" asp-for="Email" />
    <div asp-validation-summary="ModelOnly" class="alert alert-danger mb-3"></div>
    <div class="mb-4">
        <label asp-for="NewPassword" class="form-label">Yeni Parola</label>
        <input asp-for="NewPassword" class="form-control" type="password" placeholder="••••••••" />
        <span asp-validation-for="NewPassword" class="text-danger"></span>
    </div>
    <div class="d-grid">
        <button type="submit" class="btn btn-primary">Kaydet</button>
    </div>
</form>

<div class="auth-footer mt-4">
    <a asp-action="Login" asp-route-role="@role" class="back-link-highlight">Giriş ekranına dön</a>
</div>