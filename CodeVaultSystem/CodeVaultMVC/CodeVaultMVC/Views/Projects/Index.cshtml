@model IEnumerable<CodeVaultMVC.Models.Projects>
@{
    ViewData["Title"] = "Projeler";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h5 class="fw-bold mb-0">Projeler</h5>
    <a asp-action="Create" class="btn btn-primary btn-sm"><i class="bi bi-plus-lg me-1"></i>Yeni Proje</a>
</div>

<div class="card">
    <div class="card-body p-0">
        <table class="table mb-0">
            <thead>
                <tr>
                    <th class="ps-4">Proje Adı</th>
                    <th>Açıklama</th>
                    <th>Durum</th>
                    <th>Link</th>
                    <th class="text-center">İşlemler</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td class="ps-4 fw-semibold">@item.ProjectName</td>
                        <td class="text-muted small">@item.Description</td>
                        <td><span class="badge bg-primary">@item.Status</span></td>
                        <td><a href="@item.ProjectUrl" target="_blank" class="text-decoration-none small text-primary">@item.ProjectUrl</a></td>
                        <td class="text-center">
                            <a asp-action="Edit" asp-route-id="@item.ProjeID" class="btn btn-sm btn-outline-primary me-1">Düzenle</a>
                            <a asp-action="Delete" asp-route-id="@item.ProjeID" class="btn btn-sm btn-outline-danger">Sil</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>