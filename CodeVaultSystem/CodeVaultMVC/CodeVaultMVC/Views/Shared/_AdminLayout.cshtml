@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <title>@ViewData["Title"] - CodeVault Admin</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <style>
            body {
                background: #0f172a;
                font-family: 'Outfit', sans-serif;
                color: #cbd5e1;
            }

            .sidebar {
                width: 260px;
                min-height: 100vh;
                background: #0b0f19;
                border-right: 1px solid #334155;
                position: fixed;
                top: 0;
                left: 0;
                display: flex;
                flex-direction: column;
                padding: 0;
                z-index: 100;
            }

            .sidebar-brand {
                padding: 24px 20px;
                border-bottom: 1px solid #334155;
            }

                .sidebar-brand h4 {
                    background: linear-gradient(135deg, #f43f5e, #fda4af);
                    -webkit-background-clip: text;
                    -webkit-text-fill-color: transparent;
                    font-weight: 700;
                    margin: 0;
                    font-size: 1.3rem;
                    letter-spacing: 0.5px;
                }

                .sidebar-brand small {
                    color: rgba(255,255,255,0.4);
                    font-size: 0.7rem;
                }

            .sidebar .nav-link {
                color: #94a3b8;
                padding: 12px 20px;
                border-radius: 8px;
                margin: 2px 10px;
                font-size: 0.9rem;
                transition: all 0.2s;
                display: flex;
                align-items: center;
                gap: 10px;
            }

                .sidebar .nav-link:hover, .sidebar .nav-link.active {
                    background: rgba(244, 63, 94, 0.12);
                    color: #f43f5e;
                }

            .sidebar .nav-label {
                color: rgba(255,255,255,0.25);
                font-size: 0.7rem;
                text-transform: uppercase;
                letter-spacing: 1px;
                padding: 16px 20px 4px;
            }

            .main-content {
                margin-left: 260px;
                padding: 30px;
                min-height: 100vh;
                background: #0f172a;
            }

            .topbar {
                background: #1e293b;
                border-radius: 16px;
                padding: 16px 24px;
                margin-bottom: 24px;
                display: flex;
                justify-content: space-between;
                align-items: center;
                border: 1px solid #334155;
                box-shadow: 0 4px 20px rgba(0,0,0,0.15);
            }

            .card {
                border: 1px solid #334155;
                border-radius: 16px;
                box-shadow: 0 4px 20px rgba(0, 0, 0, 0.25);
                background: #1e293b;
                overflow: hidden;
            }

            .btn {
                border-radius: 10px;
                font-weight: 500;
                padding: 8px 16px;
                transition: all 0.2s;
            }

            .btn-primary {
                background: linear-gradient(135deg, #f43f5e 0%, #fda4af 100%);
                border: none;
                color: #ffffff;
            }
            .btn-primary:hover {
                background: linear-gradient(135deg, #e11d48 0%, #f43f5e 100%);
                transform: translateY(-1px);
                box-shadow: 0 4px 12px rgba(244, 63, 94, 0.3);
                color: #ffffff;
            }

            .btn-outline-secondary {
                border-color: #475569;
                color: #94a3b8;
            }
            .btn-outline-secondary:hover {
                background-color: #334155;
                color: #cbd5e1;
                border-color: #475569;
            }

            .form-control, .form-select {
                border: 1px solid #475569;
                border-radius: 10px;
                padding: 10px 14px;
                font-size: 0.95rem;
                background-color: #0f172a;
                color: #f1f5f9;
                transition: all 0.2s ease-in-out;
            }
            .form-control::placeholder {
                color: #64748b !important;
                opacity: 0.8;
            }

            .form-control:focus, .form-select:focus {
                border-color: #f43f5e;
                box-shadow: 0 0 0 3px rgba(244, 63, 94, 0.25);
                outline: none;
                color: #f1f5f9;
                background-color: #0f172a;
            }

            .form-label {
                font-weight: 500;
                font-size: 0.9rem;
                color: #94a3b8;
                margin-bottom: 6px;
            }

            .table {
                margin-bottom: 0;
                background-color: transparent;
            }

            .table thead th {
                font-size: 0.75rem;
                text-transform: uppercase;
                letter-spacing: 0.05em;
                color: #94a3b8;
                border-bottom: 1px solid #334155;
                padding: 16px 20px;
                font-weight: 600;
                background-color: #1e293b;
                border-top: none;
            }

            .table td {
                vertical-align: middle;
                padding: 16px 20px;
                border-bottom: 1px solid #334155;
                color: #cbd5e1;
                background-color: #1e293b;
            }

            .table tr {
                background-color: #1e293b;
            }

            .badge {
                border-radius: 8px;
                font-weight: 600;
                padding: 6px 12px;
                font-size: 0.75rem;
            }

            .alert-danger {
                background-color: rgba(239, 68, 68, 0.1);
                border-color: rgba(239, 68, 68, 0.3);
                color: #fca5a5;
            }

            .text-muted {
                color: #94a3b8 !important;
            }

            h5, h4, h3, h2, h1 {
                color: #f1f5f9;
            }

            @@media (max-width: 991.98px) {
                .sidebar {
                    width: 100%;
                    min-height: auto;
                    position: relative;
                    border-right: none;
                    border-bottom: 1px solid #334155;
                }
                .main-content {
                    margin-left: 0;
                    padding: 20px;
                }
                .topbar {
                    flex-direction: column;
                    align-items: flex-start;
                    gap: 12px;
                }
            }
    </style>
</head>
<body>
    <div class="sidebar">
        <div class="sidebar-brand">
            <a asp-controller="Admin" asp-action="Index" style="text-decoration: none; color: inherit;">
                <h4><i class="bi bi-code-slash me-2"></i>CodeVault</h4>
            </a>
            <small>Admin Panel</small>
        </div>
        <div class="mt-3">
            <div class="nav-label">Genel</div>
            <a class="nav-link" asp-controller="Admin" asp-action="Index">
                <i class="bi bi-grid-1x2"></i> Dashboard
            </a>
            <div class="nav-label">Yönetim</div>
            <a class="nav-link" asp-controller="Projects" asp-action="Index">
                <i class="bi bi-folder2"></i> Projeler
            </a>
            <a class="nav-link" asp-controller="Developers" asp-action="Index">
                <i class="bi bi-people"></i> Geliştiriciler
            </a>
            <a class="nav-link" asp-controller="Technologies" asp-action="Index">
                <i class="bi bi-cpu"></i> Teknolojiler
            </a>
        </div>
        <div class="mt-auto p-3">
            <a asp-controller="Account" asp-action="Logout" class="nav-link text-danger">
                <i class="bi bi-box-arrow-left"></i> Çıkış Yap
            </a>
        </div>
    </div>
    <div class="main-content">
        <div class="topbar">
            <h6 class="mb-0 fw-semibold text-muted">@ViewData["Title"]</h6>
            <span class="text-muted small"><i class="bi bi-person-circle me-1"></i>@User.Identity?.Name</span>
        </div>
        @RenderBody()
    </div>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>