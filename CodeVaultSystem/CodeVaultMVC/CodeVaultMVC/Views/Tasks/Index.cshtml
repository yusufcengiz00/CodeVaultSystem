@model IEnumerable<CodeVaultMVC.ViewModels.TaskListVM>
@{
    ViewData["Title"] = "Görevler";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h5 class="fw-bold mb-0">Tüm Görevler</h5>
    <a asp-action="Create" class="btn btn-primary btn-sm"><i class="bi bi-plus-lg me-1"></i>Yeni Görev</a>
</div>

<div class="card">
    <div class="card-body p-0">
        <table class="table mb-0">
            <thead>
                <tr>
                    <th class="ps-5">Görev</th>
                    <th>Açıklama</th>
                    <th>Proje</th>
                    <th>Geliştirici</th>
                    <th>Teknoloji</th>
                    <th>Durum</th>
                    <th class="text-center">İşlemler</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td class="ps-4 fw-semibold">@item.TaskName</td>
                        <td class="ps-4 fw-semibold">@item.Description</td>
                        <td class="text-muted small">@item.ProjectName</td>
                        <td class="text-muted small">@item.DeveloperName</td>
                        <td class="text-muted small">@item.TechnologyName</td>
                        <td>
                            @{
                                var badgeClass = item.Status switch
                                {
                                    "Tamamlandı" => "bg-success",
                                    "Yapılıyor" => "bg-warning text-dark",
                                    _ => "bg-secondary"
                                };
                            }
                            <span class="badge @badgeClass">@item.Status</span>
                        </td>
                        <td class="text-center">
                            <a asp-action="Edit" asp-route-id="@item.TaskID" class="btn btn-sm btn-outline-primary me-1">Düzenle</a>
                            <a asp-action="Delete" asp-route-id="@item.TaskID" class="btn btn-sm btn-outline-danger">Sil</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>