@model IEnumerable<CodeVaultMVC.Models.Developers>
@{
    ViewData["Title"] = "Geliştiriciler";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h5 class="fw-bold mb-0">Geliştiriciler</h5>
    <a asp-action="Create" class="btn btn-primary btn-sm"><i class="bi bi-plus-lg me-1"></i>Yeni Geliştirici</a>
</div>

<div class="card">
    <div class="card-body p-0">
        <table class="table mb-0">
            <thead>
                <tr>
                    <th class="ps-4">Ad Soyad</th>
                    <th>E-Mail</th>
                    <th>GitHub</th>
                    <th>LinkedIn</th>
                    <th class="text-center">İşlemler</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td class="ps-4 fw-semibold">@item.FullName</td>
                        <td class="text-muted small">@item.EMail</td>
                        <td><a href="@item.GithubUrl" target="_blank" class="text-decoration-none small">@item.GithubUrl</a></td>
                        <td><a href="@item.LinkedinUrl" target="_blank" class="text-decoration-none small">@item.LinkedinUrl</a></td>
                        <td class="text-center">
                            <a asp-action="Edit" asp-route-id="@item.DeveloperID" class="btn btn-sm btn-outline-primary me-1">Düzenle</a>
                            <a asp-action="Delete" asp-route-id="@item.DeveloperID" class="btn btn-sm btn-outline-danger">Sil</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>