@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <title>@ViewData["Title"] - CodeVault</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <style>
            body {
                background: #0f172a;
                font-family: 'Outfit', sans-serif;
                color: #cbd5e1;
            }

            .navbar {
                background: #1e293b;
                border-bottom: 1px solid #334155;
                padding: 16px 0;
            }

            .navbar-brand {
                font-weight: 700;
                color: #ffffff !important;
                font-size: 1.3rem;
                letter-spacing: -0.5px;
            }

                .navbar-brand span {
                    background: linear-gradient(135deg, #818cf8, #c084fc);
                    -webkit-background-clip: text;
                    -webkit-text-fill-color: transparent;
                }

            .nav-link {
                color: #94a3b8 !important;
                font-size: 0.95rem;
                font-weight: 500;
                transition: color 0.2s;
            }

                .nav-link:hover {
                    color: #818cf8 !important;
                }

                .nav-link.text-danger {
                    color: #f87171 !important;
                }
                .nav-link.text-danger:hover {
                    color: #ef4444 !important;
                }

            .card {
                border: 1px solid #334155;
                border-radius: 16px;
                box-shadow: 0 4px 20px rgba(0, 0, 0, 0.25);
                background: #1e293b;
                overflow: hidden;
            }

            .btn {
                border-radius: 10px;
                font-weight: 500;
                padding: 8px 16px;
                transition: all 0.2s;
            }

            .btn-primary {
                background: linear-gradient(135deg, #6366f1 0%, #8b5cf6 100%);
                border: none;
                color: #ffffff;
            }
            .btn-primary:hover {
                background: linear-gradient(135deg, #4f46e5 0%, #7c3aed 100%);
                transform: translateY(-1px);
                box-shadow: 0 4px 12px rgba(99, 102, 241, 0.3);
                color: #ffffff;
            }

            .btn-outline-secondary {
                border-color: #475569;
                color: #94a3b8;
            }
            .btn-outline-secondary:hover {
                background-color: #334155;
                color: #cbd5e1;
                border-color: #475569;
            }

            .btn-outline-primary {
                border-color: #6366f1;
                color: #818cf8;
            }
            .btn-outline-primary:hover {
                background-color: #6366f1;
                color: #ffffff;
                border-color: #6366f1;
            }

            .btn-outline-danger {
                border-color: #ef4444;
                color: #f87171;
            }
            .btn-outline-danger:hover {
                background-color: #ef4444;
                color: #ffffff;
                border-color: #ef4444;
            }

            .form-control, .form-select {
                border: 1px solid #475569;
                border-radius: 10px;
                padding: 10px 14px;
                font-size: 0.95rem;
                background-color: #0f172a;
                color: #f1f5f9;
                transition: all 0.2s ease-in-out;
            }
            .form-control::placeholder {
                color: #64748b !important;
                opacity: 0.8;
            }

            .form-control:focus, .form-select:focus {
                border-color: #818cf8;
                box-shadow: 0 0 0 3px rgba(129, 140, 248, 0.25);
                outline: none;
                color: #f1f5f9;
                background-color: #0f172a;
            }

            .form-label {
                font-weight: 500;
                font-size: 0.9rem;
                color: #94a3b8;
                margin-bottom: 6px;
            }

            .table {
                margin-bottom: 0;
                background-color: transparent;
            }

            .table thead th {
                font-size: 0.75rem;
                text-transform: uppercase;
                letter-spacing: 0.05em;
                color: #94a3b8;
                border-bottom: 1px solid #334155;
                padding: 16px 20px;
                font-weight: 600;
                background-color: #1e293b;
            }

            .table td {
                vertical-align: middle;
                padding: 16px 20px;
                border-bottom: 1px solid #334155;
                color: #cbd5e1;
                background-color: #1e293b;
            }

            .table tr {
                background-color: #1e293b;
            }

            .badge {
                border-radius: 8px;
                font-weight: 600;
                padding: 6px 12px;
                font-size: 0.75rem;
            }

            .main-wrap {
                padding: 40px 0;
            }

            .alert-danger {
                background-color: rgba(239, 68, 68, 0.1);
                border-color: rgba(239, 68, 68, 0.3);
                color: #fca5a5;
            }

            .text-muted {
                color: #94a3b8 !important;
            }

            h5, h4, h3, h2, h1 {
                color: #f1f5f9;
            }
    </style>
</head>
<body>
    <nav class="navbar navbar-expand-lg">
        <div class="container">
            <a class="navbar-brand" asp-controller="User" asp-action="Index">Code<span>Vault</span></a>
            <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav" aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation" style="box-shadow: none;">
                <span class="navbar-toggler-icon" style="filter: invert(1) grayscale(1) brightness(0.85);"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <div class="navbar-nav ms-auto gap-2 gap-lg-4 mt-3 mt-lg-0">
                    <a class="nav-link" asp-controller="User" asp-action="Index">
                        <i class="bi bi-house-door me-1"></i>Ana Sayfa
                    </a>
                    <a class="nav-link" asp-controller="Tasks" asp-action="Index">
                        <i class="bi bi-list-task me-1"></i>Görevler
                    </a>
                    <a class="nav-link" asp-controller="Comments" asp-action="Index">
                        <i class="bi bi-chat-left-text me-1"></i>Yorumlar
                    </a>
                    <a class="nav-link text-danger" asp-controller="Account" asp-action="Logout">
                        <i class="bi bi-box-arrow-right me-1"></i>Çıkış
                    </a>
                </div>
            </div>
        </div>
    </nav>
    <div class="main-wrap">
        <div class="container">
            @RenderBody()
        </div>
    </div>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>