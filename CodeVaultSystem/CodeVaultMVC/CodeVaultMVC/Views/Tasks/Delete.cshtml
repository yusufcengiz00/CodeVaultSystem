@model CodeVaultMVC.Models.MVC_Tables.Tasks
@{
    ViewData["Title"] = "Görev Sil";
}

<div class="card col-md-6 mx-auto" style="border: 1px solid #fecaca; box-shadow: 0 4px 25px rgba(239, 68, 68, 0.05);">
    <div class="card-body p-4 p-md-5 text-center">
        <div style="background: rgba(239, 68, 68, 0.1); color: #ef4444; border-radius: 50%; width: 70px; height: 70px; display: flex; align-items: center; justify-content: center; margin: 0 auto 24px auto; font-size: 2.2rem;">
            <i class="bi bi-exclamation-triangle"></i>
        </div>
        <h4 class="fw-bold text-danger mb-2">Silme Onayı</h4>
        <p class="text-muted mb-4"><strong>@Model.TaskName</strong> isimli görevi silmek istediğinize emin misiniz? Bu işlem geri alınamaz.</p>

        <form asp-action="Delete" method="post">
            <input type="hidden" asp-for="TaskID" />
            <div class="d-flex justify-content-center gap-2 border-top pt-4">
                <a asp-action="Index" class="btn btn-outline-secondary px-4">Vazgeç</a>
                <button type="submit" class="btn btn-danger px-4 text-white" style="background: linear-gradient(135deg, #ef4444 0%, #dc2626 100%); border: none;">Evet, Görevi Sil</button>
            </div>
        </form>
    </div>
</div>