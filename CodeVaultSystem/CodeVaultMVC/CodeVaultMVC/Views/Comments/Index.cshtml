@model IEnumerable<CodeVaultMVC.ViewModels.CommentListVM>
@{
    ViewData["Title"] = "Yorumlar";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h5 class="fw-bold mb-0">Yorumlar</h5>
    <a asp-action="Create" class="btn btn-primary btn-sm"><i class="bi bi-plus-lg me-1"></i>Yeni Yorum</a>
</div>

<div class="card">
    <div class="card-body p-0">
        <table class="table mb-0">
            <thead>
                <tr>
                    <th class="ps-4">Yorum</th>
                    <th>Kullanıcı</th>
                    <th>Görev</th>
                    <th>Tarih</th>
                    <th class="text-center">İşlemler</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td class="ps-4">@item.Content</td>
                        <td class="text-muted small">@item.UserName</td>
                        <td class="text-muted small">@item.TaskName</td>
                        <td class="text-muted small">@item.CreatedAt.ToString("dd.MM.yyyy HH:mm")</td>
                        <td class="text-center">
                            <a asp-action="Edit" asp-route-id="@item.CommentID" class="btn btn-sm btn-outline-primary me-1">Düzenle</a>
                            <a asp-action="Delete" asp-route-id="@item.CommentID" class="btn btn-sm btn-outline-danger">Sil</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>