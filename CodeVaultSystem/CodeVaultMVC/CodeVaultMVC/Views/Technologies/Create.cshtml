@model CodeVaultMVC.Models.Technologies
@{
    ViewData["Title"] = "Yeni Teknoloji";
}

<div class="card col-md-6 mx-auto">
    <div class="card-body p-4">
        <h5 class="fw-bold mb-4">Yeni Teknoloji Ekle</h5>
        <form asp-action="Create" method="post">
            <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>
            <div class="mb-3">
                <label class="form-label">Teknoloji Adı</label>
                <input asp-for="TechnologyName" class="form-control" required />
            </div>
            <div class="mb-3">
                <label class="form-label">Kategori</label>
                <input asp-for="Category" class="form-control" />
            </div>
            <div class="mb-4">
                <label class="form-label">Versiyon</label>
                <input asp-for="Version" class="form-control" />
            </div>
            <button type="submit" class="btn btn-primary">Kaydet</button>
            <a asp-action="Index" class="btn btn-outline-secondary ms-2">İptal</a>
        </form>
    </div>
</div>